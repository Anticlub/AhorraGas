<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C2C3A">

    <!-- Columna principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Cabecera -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1A237E"
            android:gravity="center"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Preferencias"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════ -->
        <!-- SECCIÓN: Radio de búsqueda                        -->
        <!-- ══════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Radio de búsqueda"
            android:textColor="#4DB6AC"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp"
            android:background="#383848" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2C2C3A"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Fila: etiqueta izquierda + valor derecha -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Distancia máxima"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvRadiusValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 km"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Slider + límites -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 km"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginEnd="6dp" />

                <SeekBar
                    android:id="@+id/seekBarRadius"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="49"
                    android:progress="9"
                    android:thumbTint="#4DB6AC"
                    android:progressTint="#4DB6AC"
                    android:progressBackgroundTint="#555566" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50 km"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Afecta al botón «Mostrar cerca» del mapa."
                android:textColor="#888888"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════ -->
        <!-- SECCIÓN: Mis vehículos                            -->
        <!-- ══════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mis vehículos  (toca uno para activarlo)"
            android:textColor="#4DB6AC"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp"
            android:background="#383848" />

        <!-- Lista scrollable de vehículos -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/vehicleListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="88dp" />

        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavPrefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A237E"
            app:menu="@menu/bottom_nav_menu"
            app:itemIconTint="@color/white"
            app:itemTextColor="@color/white"
            app:labelVisibilityMode="labeled" />

    </LinearLayout>

    <!-- FAB flotante para añadir vehículo -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddVehicle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="72dp"
        android:contentDescription="Añadir vehículo"
        app:srcCompat="@android:drawable/ic_input_add"
        app:backgroundTint="#4DB6AC"
        app:tint="@color/white"
        app:fabSize="normal"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>