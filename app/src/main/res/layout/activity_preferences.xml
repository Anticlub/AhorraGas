<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C2C3A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Cabecera -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1A237E"
            android:gravity="center"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Preferencias"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="88dp">

                <!-- ══════════════════════════════════════════════════ -->
                <!-- SECCIÓN: Mis vehículos                            -->
                <!-- ══════════════════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#383848"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mis vehículos  (toca uno para activarlo)"
                        android:textColor="#4DB6AC"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnAddVehicle"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="+ Añadir"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:backgroundTint="#4DB6AC"
                        android:textColor="#FFFFFF"
                        android:paddingHorizontal="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/vehicleListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingTop="8dp" />

                <!-- ══════════════════════════════════════════════════ -->
                <!-- SECCIÓN: Radio de búsqueda                        -->
                <!-- ══════════════════════════════════════════════════ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Radio de búsqueda"
                    android:textColor="#4DB6AC"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp"
                    android:background="#383848" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#2C2C3A"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Distancia máxima"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvRadiusValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10 km"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 km"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginEnd="6dp" />

                        <SeekBar
                            android:id="@+id/seekBarRadius"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="49"
                            android:progress="9"
                            android:thumbTint="#4DB6AC"
                            android:progressTint="#4DB6AC"
                            android:progressBackgroundTint="#555566" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50 km"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Afecta a la busqueda de gasolineras."
                        android:textColor="#888888"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- SECCIÓN: Gasolineras visibles en el mapa          -->
                <!-- ══════════════════════════════════════════════════ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gasolineras visibles en el mapa"
                    android:textColor="#4DB6AC"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp"
                    android:background="#383848" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#2C2C3A"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Máximo de marcadores"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvMarkersValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekBarMarkers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="149"
                        android:progress="99"
                        android:thumbTint="#4DB6AC"
                        android:progressTint="#4DB6AC"
                        android:progressBackgroundTint="#555566" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Número de gasolineras mostradas en el mapa (1–150)."
                        android:textColor="#888888"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- SECCIÓN: Mis descuentos                           -->
                <!-- ══════════════════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#383848"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mis descuentos"
                        android:textColor="#4DB6AC"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnAddDiscount"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="+ Añadir"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:backgroundTint="#FF7043"
                        android:textColor="#FFFFFF"
                        android:paddingHorizontal="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/discountListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingTop="8dp" />

                <!-- ══════════════════════════════════════════════════ -->
                <!-- SECCIÓN: Mis alertas de precio                    -->
                <!-- ══════════════════════════════════════════════════ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mis alertas de precio"
                    android:textColor="#4DB6AC"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp"
                    android:background="#383848" />

                <LinearLayout
                    android:id="@+id/alertListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingTop="8dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavPrefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A237E"
            app:menu="@menu/bottom_nav_menu"
            app:itemIconTint="@color/white"
            app:itemTextColor="@color/white"
            app:labelVisibilityMode="labeled" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>